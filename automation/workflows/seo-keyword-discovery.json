        {
            "id": "kd-008",
            "name": "Build Context",
            "type": "n8n-nodes-base.code",
            "typeVersion": 2,
            "position": [
                1580,
                390
            ],
            "parameters": {
                "jsCode": "const keywordQueueRows = $('Read Keyword Queue').all();\nconst publishedPostsRows = $('Read Published Posts').all();\nconst serviceAreaRows = $('Read Service Areas').all();\nconst serviceRows = $('Read Services').all();\nconst brandVoiceRows = $('Read Brand Voice').all();\n\nconst existingSet = new Set();\nkeywordQueueRows.forEach(r => { if (r.json.Keyword) existingSet.add(r.json.Keyword.toLowerCase().trim()); });\npublishedPostsRows.forEach(r => { if (r.json.Keyword) existingSet.add(r.json.Keyword.toLowerCase().trim()); });\n\nconst existingKeywordsList = Array.from(existingSet).join('\\n');\n\nconst serviceAreasText = serviceAreaRows\n  .map(r => `${r.json.City}, ${r.json.State} — ${r.json.Content_Angle || ''}`)\n  .join('\\n');\n\nconst servicesText = serviceRows\n  .map(r => `${r.json.Size}-Yard Dumpster: Base price ${r.json.Base_Price}, Best for: ${r.json.Best_For}`)\n  .join('\\n');\n\nconst brandVoiceText = brandVoiceRows\n  .filter(r => r.json.Category && r.json.Guideline)\n  .map(r => `${r.json.Category}: ${r.json.Guideline}`)\n  .join('\\n');\n\nconst currentMonth = new Date().toLocaleString('en-US', { month: 'long' });\n\nconst prompt = `You are an SEO keyword research expert for MidSouth Dumpster Rentals, a locally-owned dumpster rental company serving Central Mississippi (Jackson, MS metro area).\n\nTASK: Discover exactly 7 new, unique keyword opportunities NOT in the existing list.\n\nBUSINESS CONTEXT:\n- Company: MidSouth Dumpster Rentals (locally owned, Jackson MS)\n- Phone: 601-316-7891\n- Hours: 7AM-7PM, 7 days/week, same-day delivery available\n\nSERVICES:\n${servicesText}\n\nSERVICE AREAS:\n${serviceAreasText}\n\nBRAND VOICE:\n${brandVoiceText}\n\nCURRENT MONTH: ${currentMonth}\n\nEXISTING KEYWORDS - DO NOT DUPLICATE ANY OF THESE:\n${existingKeywordsList}\n\nSEARCH STRATEGY - Use 5-7 tavily_search calls:\n1. Search 'dumpster rental Jackson MS' and similar — find competitor keywords and People Also Ask\n2. Find uncovered [service type] + [city] combos from the service areas list\n3. Search informational queries: sizing guides, permit questions, cost guides for Mississippi\n4. Find seasonal opportunities for ${currentMonth}\n5. Search 'dumpster rental [city] MS' for expansion target cities\n\nOUTPUT: Return ONLY valid JSON in this exact format (no other text):\n{\n  \"keywords\": [\n    {\n      \"keyword\": \"exact keyword phrase\",\n      \"type\": \"long-tail|informational|neighborhood\",\n      \"priority\": \"high|medium|low\",\n      \"location\": \"City, MS\"\n    }\n  ]\n}\n\nRules:\n- Exactly 7 keywords\n- No duplicates with existing list\n- Mix of types (long-tail, informational, neighborhood)\n- High priority = clear commercial/local intent`;\n\nreturn [{ json: { prompt, existingKeywords: existingKeywordsList } }];"
            }
        },
        {
            "id": "kd-009",
            "name": "Keyword Discovery Agent",
            "type": "@n8n/n8n-nodes-langchain.agent",
            "typeVersion": 1.7,
            "position": [
                1800,
                390
