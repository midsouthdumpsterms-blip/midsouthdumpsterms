            "parameters": {
                "agent": "toolsAgent",
                "promptType": "define",
                "text": "={{ $json.prompt }}",
                "options": {
                    "systemMessage": "You are an SEO keyword research specialist for a local dumpster rental business in Jackson, Mississippi. You are methodical and data-driven. You always return valid JSON. You use search tools to find real keyword opportunities, not guesses.",
                    "maxIterations": 10,
                    "returnIntermediateSteps": false
                }
            }
        },
