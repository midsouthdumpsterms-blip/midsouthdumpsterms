        {
            "id": "kd-011",
            "name": "Tavily Search",
            "type": "@n8n/n8n-nodes-langchain.toolHttpRequest",
            "typeVersion": 1.1,
            "position": [
                1680,
                720
            ],
            "parameters": {
                "name": "tavily_search",
                "description": "Search the web for information. Use to research dumpster rental keywords, competitor content, and local Mississippi market data.",
                "method": "POST",
                "url": "https://api.tavily.com/search",
                "sendBody": true,
                "contentType": "json",
                "bodyParameters": {
                    "parameters": [
                        {
                            "name": "api_key",
                            "value": "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"
                        },
                        {
                            "name": "query",
                            "value": "={{ /*n8n-auto-generated-fromAI-override*/ $fromAI('query', 'The search query to execute', 'string') }}"
                        },
                        {
                            "name": "max_results",
                            "value": "5"
                        },
                        {
                            "name": "search_depth",
                            "value": "basic"
                        }
                    ]
                }
            }
        },
        {
            "id": "kd-013",
            "name": "Parse Keywords",
            "type": "n8n-nodes-base.code",
            "typeVersion": 2,
            "position": [
                2020,
                390
            ],
            "parameters": {
                "jsCode": "const agentOutput = $input.first().json.output || '';\nconst existingRaw = $('Build Context').first().json.existingKeywords || '';\nconst existingSet = new Set(existingRaw.split('\\n').map(k => k.toLowerCase().trim()).filter(k => k));\n\nlet keywords = [];\ntry {\n  const jsonMatch = agentOutput.match(/\\{[\\s\\S]*\\\"keywords\\\"[\\s\\S]*\\}/);\n  if (jsonMatch) {\n    const parsed = JSON.parse(jsonMatch[0]);\n    keywords = parsed.keywords || [];\n  }\n} catch(e) {\n  return [{ json: { keywords: [], count: 0, error: 'JSON parse failed: ' + e.message } }];\n}\n\nconst validTypes = ['long-tail', 'informational', 'neighborhood'];\nconst validPriorities = ['high', 'medium', 'low'];\nconst seenInBatch = new Set();\nconst today = new Date().toISOString().split('T')[0];\n\nconst clean = keywords\n  .filter(kw => {\n    if (!kw.keyword || typeof kw.keyword !== 'string') return false;\n    const norm = kw.keyword.toLowerCase().trim();\n    if (existingSet.has(norm)) return false;\n    if (seenInBatch.has(norm)) return false;\n    seenInBatch.add(norm);\n    return true;\n  })\n  .map(kw => ({\n    Keyword: kw.keyword.trim(),\n    Type: validTypes.includes(kw.type) ? kw.type : 'long-tail',\n    Priority: validPriorities.includes(kw.priority) ? kw.priority : 'medium',\n    Location: kw.location || 'Jackson, MS',\n    Status: 'pending',\n    Date_Queued: today,\n    Date_Published: ''\n  }));\n\nreturn [{ json: { keywords: clean, count: clean.length } }];"
            }
        },
